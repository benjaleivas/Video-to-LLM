# Optional cloud providers for videopipe
# AssemblyAI transcription + diarization
ASSEMBLYAI_API_KEY=

# Google Cloud Vision OCR credentials JSON path
# Recommended: gcloud ADC user creds file
GOOGLE_APPLICATION_CREDENTIALS=/Users/your-user/.config/gcloud/application_default_credentials.json

# Azure Vision Read fallback OCR (optional when --ocr-fallback-provider azure)
AZURE_VISION_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com
AZURE_VISION_KEY=
